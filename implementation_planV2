## Event Pipeline (EventEmitter)

```javascript
// eventBus.service.js
const EventEmitter = require('events');
const bus = new EventEmitter();

// Listeners registered at server startup:
bus.on('BATCH_CREATED',  (data) => hashChainService.append(data));
bus.on('BATCH_RECEIVED', (data) => hashChainService.append(data));
bus.on('QUALITY_RATED',  (data) => hashChainService.append(data));
bus.on('QUALITY_RATED',  (data) => fraudService.analyze(data));  // auto-check
bus.on('FRAUD_FLAGGED',  (data) => hashChainService.append(data));
bus.on('BATCH_VERIFIED', (data) => hashChainService.append(data));

// Usage in route handlers:
bus.emit('BATCH_CREATED', { batchId, farmerId, herb, quantity, ... });
```

